# Headers de segurança reutilizáveis (aplicados nos painéis administrativos).
# Obs.: o desafio 401 do basic_auth NÃO carrega estes headers (o Caddy escreve
# o erro fora do wrapper de headers); eles valem nas respostas já autenticadas.
# Na borda, o Cloudflare Access cobre o restante.
(secure_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

viajandocomananda.com, www.viajandocomananda.com {
	# O painel admin NÃO é acessível pelo domínio público —
	# só pelo subdomínio admin.
	@admin path /admin /admin/*
	handle @admin {
		respond 404
	}
	handle {
		reverse_proxy flask:5000
	}
}

# Painel administrativo (leads + conversas).
# Autenticação primária: Cloudflare Access (borda, SSO+MFA).
# Origem: quem traz o "segredo de origem" (injetado pela Cloudflare) entra
# direto; sem o segredo (acesso direto ao IP) cai no basic_auth de fallback —
# assim não há login duplo via Cloudflare e ninguém fica trancado.
# FASE 2 (final): trocar o fallback por 403, removendo o basic_auth.
admin.viajandocomananda.com {
	import secure_headers
	@nosecret not header X-Origin-Secret {$ORIGIN_SHARED_SECRET}
	basic_auth @nosecret {
		admin {env.ADMIN_PASS_HASH}
	}
	rewrite / /admin
	reverse_proxy flask:5000
}

# UI do Langflow (gestão do fluxo). Mesmo esquema do painel admin.
langflow.viajandocomananda.com {
	import secure_headers
	@nosecret not header X-Origin-Secret {$ORIGIN_SHARED_SECRET}
	basic_auth @nosecret {
		admin {env.LANGFLOW_PASS_HASH}
	}
	reverse_proxy langflow:7860
}
