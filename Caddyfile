viajandocomananda.com, www.viajandocomananda.com {
    reverse_proxy flask:5000
}

# Acesso à UI do Langflow (gestão do fluxo) — protegido por senha.
# O hash bcrypt é lido da variável LANGFLOW_PASS_HASH no .env.
# Para gerar um novo hash:
#   docker run --rm caddy:alpine caddy hash-password --plaintext 'sua-senha'
# Ao salvar no .env, dobre cada $ (ex: $2a$14$... vira $$2a$$14$$...)
# para escapar a interpolação do Docker Compose.
langflow.viajandocomananda.com {
    basic_auth {
        admin {env.LANGFLOW_PASS_HASH}
    }
    reverse_proxy langflow:7860
}
