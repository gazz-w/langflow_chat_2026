# Headers de segurança reutilizáveis (aplicados nos painéis administrativos).
(secure_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

viajandocomananda.com, www.viajandocomananda.com {
	# O painel admin NÃO é acessível pelo domínio público —
	# só pelo subdomínio admin.
	@admin path /admin /admin/*
	handle @admin {
		respond 404
	}
	handle {
		reverse_proxy flask:5000
	}
}

# Painel administrativo (leads + conversas).
# Autenticação na borda: Cloudflare Access (SSO + OTP). Na origem exigimos o
# "segredo de origem" que a Cloudflare injeta (header X-Origin-Secret): quem o
# traz é proxiado; acesso direto ao IP sem o segredo é bloqueado com 403.
admin.viajandocomananda.com {
	import secure_headers
	@hassecret header X-Origin-Secret {$ORIGIN_SHARED_SECRET}
	handle @hassecret {
		rewrite / /admin
		reverse_proxy flask:5000
	}
	handle {
		respond "Forbidden" 403
	}
}

# UI do Langflow (gestão do fluxo). Mesmo esquema do painel admin.
langflow.viajandocomananda.com {
	import secure_headers
	@hassecret header X-Origin-Secret {$ORIGIN_SHARED_SECRET}
	handle @hassecret {
		reverse_proxy langflow:7860
	}
	handle {
		respond "Forbidden" 403
	}
}
