# ── Desenvolvimento local ──────────────────────────────────────
# LANGFLOW_BASE_URL=http://127.0.0.1:7860

# ── Produção (Docker Compose) ──────────────────────────────────
# Em produção os serviços se falam pelo nome do container.
LANGFLOW_BASE_URL=http://langflow:7860

FLOW_ID=cole-aqui-o-id-do-seu-fluxo
LANGFLOW_API_KEY=cole-aqui-sua-api-key-do-langflow
MEMORY_COMPONENT_ID=Memory-XXXXX

# ── Acesso aos painéis (admin e langflow) ──────────────────────
# Autenticação na borda: Cloudflare Access (SSO + código por e-mail).
# Na origem: um "segredo compartilhado" que a Cloudflare injeta no header
# X-Origin-Secret (via Request Header Transform Rule). O Caddy exige esse
# header e bloqueia (403) qualquer acesso direto à origem sem ele. Gere com:
#   openssl rand -hex 32
ORIGIN_SHARED_SECRET=troque-por-um-valor-aleatorio-de-64-hex
