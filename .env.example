# ── Desenvolvimento local ──────────────────────────────────────
# LANGFLOW_BASE_URL=http://127.0.0.1:7860

# ── Produção (Docker Compose) ──────────────────────────────────
# Em produção os serviços se falam pelo nome do container.
LANGFLOW_BASE_URL=http://langflow:7860

FLOW_ID=cole-aqui-o-id-do-seu-fluxo
LANGFLOW_API_KEY=cole-aqui-sua-api-key-do-langflow
MEMORY_COMPONENT_ID=Memory-XXXXX

# ── Subdomínios protegidos (basic_auth via Caddy) ──────────────
# Reforço na origem, atrás do Cloudflare Access (borda). Gere com:
#   docker run --rm caddy:alpine caddy hash-password --plaintext 'sua-senha'
# Importante: dobre cada $ ao colar (ex: $2a$14$... vira $$2a$$14$$...)
LANGFLOW_PASS_HASH=$$2a$$14$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_PASS_HASH=$$2a$$14$$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
